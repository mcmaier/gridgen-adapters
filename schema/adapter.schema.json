{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GridGen Adapter",
  "description": "Schema for MacGizmo GridGen SMD adapter definitions",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "id", "name", "category", "pitch", "color",
      "throughPins", "features",
      "outline", "outlineOffset", "widthPins", "heightPins",
      "silkLabel", "overlay"
    ],
    "properties": {
      "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
      "name": { "type": "string" },
      "meta": {
        "type": "object",
        "description": "Optional metadata for attribution and licensing",
        "properties": {
          "author": { "type": "string" },
          "license": { "type": "string" },
          "source": { "type": "string" }
        },
        "additionalProperties": false
      },
      "category": { "type": "string" },
      "pitch": { "type": "number", "exclusiveMinimum": 0 },
      "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
      "throughPins": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["col", "row", "label"],
          "properties": {
            "col": { "type": "integer", "minimum": 0 },
            "row": { "type": "integer", "minimum": 0 },
            "label": { "type": "string" }
          }
        }
      },
      "features": { "$ref": "#/definitions/featureSet" },
      "optionalFeatures": { "$ref": "#/definitions/featureSet" },
      "outline": {
        "type": "object",
        "required": ["width", "height"],
        "properties": {
          "width": { "type": "number", "exclusiveMinimum": 0 },
          "height": { "type": "number", "exclusiveMinimum": 0 }
        }
      },
      "outlineOffset": {
        "type": "object",
        "required": ["x", "y"],
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      },
      "widthPins": { "type": "integer", "minimum": 1 },
      "heightPins": { "type": "integer", "minimum": 1 },
      "silkLabel": {
        "type": "object",
        "required": ["text", "x", "y", "rotation", "height"],
        "properties": {
          "text": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "rotation": { "type": "number" },
          "height": { "type": "number", "exclusiveMinimum": 0 }
        }
      },
      "overlay": { "type": "boolean" }
    }
  },
  "definitions": {
    "featureSet": {
      "type": "object",
      "properties": {
        "copper":     { "$ref": "#/definitions/featureList" },
        "mask":       { "$ref": "#/definitions/featureList" },
        "silk":       { "$ref": "#/definitions/featureList" },
        "silkText":   { "$ref": "#/definitions/featureList" },
        "copperBack": { "$ref": "#/definitions/featureList" },
        "drills":     { "$ref": "#/definitions/drillList" }
      }
    },
    "featureList": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "description": "Rectangular SMD-Pad",
            "type": "object",
            "required": ["type", "x", "y", "w", "h"],
            "properties": {
              "type": { "const": "pad" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "w": { "type": "number", "exclusiveMinimum": 0 },
              "h": { "type": "number", "exclusiveMinimum": 0 },
              "rotation": { "type": "number" }
            }
          },
          {
            "description": "Copper trace",
            "type": "object",
            "required": ["type", "x1", "y1", "x2", "y2", "w"],
            "properties": {
              "type": { "const": "trace" },
              "x1": { "type": "number" },
              "y1": { "type": "number" },
              "x2": { "type": "number" },
              "y2": { "type": "number" },
              "w": { "type": "number", "exclusiveMinimum": 0 }
            }
          },
          {
            "description": "Circle",
            "type": "object",
            "required": ["type", "x", "y", "d"],
            "properties": {
              "type": { "const": "circle" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "d": { "type": "number", "exclusiveMinimum": 0 }
            }
          },
          {
            "description": "Polyline",
            "type": "object",
            "required": ["type", "points"],
            "properties": {
              "type": { "const": "poly" },
              "points": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "object",
                  "required": ["x", "y"],
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" }
                  }
                }
              }
            }
          },
          {
            "description": "Text (silkText)",
            "type": "object",
            "required": ["type", "text", "x", "y", "height", "rotation"],
            "properties": {
              "type": { "const": "text" },
              "text": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "height": { "type": "number", "exclusiveMinimum": 0 },
              "rotation": { "type": "number" }
            }
          }
        ]
      }
    },
    "drillList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["x", "y", "drill", "size"],
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" },
          "drill": { "type": "number", "exclusiveMinimum": 0 },
          "size": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    }
  }
}
